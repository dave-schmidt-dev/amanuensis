# amanuensis local environment — copy to .env and fill in.
# .env is gitignored; .env.example is checked in. NEVER commit real values.

# --- Web app ---
# Bind address for `amanuensis serve`. Default localhost-only for security.
AMANUENSIS_HOST=127.0.0.1
AMANUENSIS_PORT=8723

# --- Logging ---
# Rotating file handler per project policy (CLAUDE.md):
#   1 MB / 2 backups, WARNING+ always, DEBUG with --debug flag.
AMANUENSIS_LOG_PATH=/tmp/amanuensis.log
AMANUENSIS_LOG_LEVEL=WARNING

# --- LLM access ---
# Amanuensis does NOT call LLM APIs directly. The agent harness
# (Claude Code / Codex / Gemini CLI / etc.) owns its own credentials.
# No keys belong in this file.

# --- Dispatch ---
# Harness CLI commands. Override if your harness binaries are
# non-standard paths. amanuensis dispatch driver invokes these
# verbatim per role assignment.
AMANUENSIS_CLI_CLAUDE=claude
AMANUENSIS_CLI_CODEX=codex
AMANUENSIS_CLI_GEMINI=gemini
AMANUENSIS_CLI_CURSOR_AGENT=cursor-agent

# --- Optional: telemetry / metrics ---
# Disabled by default. If enabled, writes to ~/Documents/Projects/.plans/metrics.jsonl
# alongside plan.md metrics — never to external endpoints.
AMANUENSIS_METRICS_ENABLED=false
